{
  "style": "~/.config/waybar/style.css",
  
  "layer": "top",
  "position": "top",
  "height": 24,
  
  "modules-left": [
    "custom/launcher",
    "hyprland/workspaces",
    "custom/weather",
    "custom/cava"
  ],
  
  // "modules-center": [
