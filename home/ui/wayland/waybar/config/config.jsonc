  "modules-right": [
    "idle_inhibitor",
    "hyprland/language",
    "keyboard-state",
    "pulseaudio",
    "network",
    "custom/vpn",
    "clock",
    "tray"
  ],

  "include": "~/.config/waybar/modules.jsonc"
}
